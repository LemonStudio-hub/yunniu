# =================================================================
# Cloudflare Workers 开发环境变量示例
# =================================================================
# ⚠️  重要安全警告 ⚠️
# =================================================================
# 
# 1. 此文件仅用于开发环境
# 2. 不要将此文件中的任何密钥用于生产环境
# 3. 生产环境必须使用 wrangler secret 命令设置密钥
# 4. 定期轮换密钥，至少每 6 个月一次
#
# 设置生产环境密钥:
#   wrangler secret put JWT_SECRET
#
# 查看已设置的密钥:
#   wrangler secret list
#
# =================================================================

# JWT 密钥（开发环境）
# ⚠️ 警告：此密钥仅用于开发环境，切勿用于生产环境！
# 密钥要求：
#   - 至少 32 个字符
#   - 包含大小写字母、数字和特殊字符
#   - 熵值至少 80 位
#
# 生产环境请使用以下命令设置：
#   wrangler secret put JWT_SECRET
#
# 示例（仅用于参考，不要直接使用）：
#   - 长度：>= 32 字符
#   - 复杂性：包含大小写字母、数字、特殊字符
#   - 避免使用常见密码（password、123456、qwerty 等）
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_FOR_DEV_ENV_ONLY

# 运行环境
ENVIRONMENT=development

# =================================================================
# 其他注意事项
# =================================================================
#
# 1. 确保此文件未被提交到版本控制系统
# 2. .dev.vars 文件已在 .gitignore 中
# 3. 不要在任何公开仓库中包含真实密钥
# 4. 定期检查 wrangler.toml 确认没有硬编码密钥
#
# =================================================================